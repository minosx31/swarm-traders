# Copy to backend/.env (gitignored) — auto-loaded by the app and build_snapshot.py.
FINNHUB_API_KEY=
# SEC EDGAR asks API callers to self-identify. Any "name contact-email" works;
# US-ticker fundamentals fall back to yfinance if this is missing.
SEC_EDGAR_USER_AGENT=swarm-traders (you@example.com)

# Default chat backend: openrouter | ollama | haiku | sonnet | groq. Required at
# startup; the UI can override backend+model per live run.
LLM_BACKEND=openrouter
# OpenRouter (OpenAI-compatible gateway) — enables the curated cheap-model picker.
OPENROUTER_API_KEY=
# Optional: default OpenRouter model when no per-run override is sent.
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Comma-separated origins allowed to call the API (CORS). Set to the deployed
# frontend origin on Render, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
